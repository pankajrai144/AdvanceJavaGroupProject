</section>

<!-- JERSEY ROW – PORTUGAL -->
<section class="section4">
    <div class="wrap2">
        <p class="text3">Portugal</p>
        <div class="grid1">

            <div class="card1">
                <div class="img1">
                    <img src="../images/ronaldo2.jpg" alt="Portugal Home 2026" />
