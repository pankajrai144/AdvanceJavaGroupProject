<%@ include file="/components/header.jsp" %>

<!-- HEADING -->
<section class="section1">
    <p class="text1">2026 FIFA World Cup</p>
    <h1>Find Your <span>Nation</span></h1>
    <p class="text2">Official jerseys from every competing nation. Pick your flag, own your kit.</p>
</section>

<!-- NATION CRESTS -->
<section class="section2">
    <div class="wrap1">

        <a href="#" class="item1">
            <img src="../images/portugal1.jpg" alt="Portugal" />
            <span>Portugal</span>
        </a>

        <a href="#" class="item1">
            <img src="../images/argentina2.jpg" alt="Argentina" />
            <span>Argentina</span>
        </a>

        <a href="#" class="item1">
            <img src="../images/brazil2.jpg" alt="Brazil" />
            <span>Brazil</span>
        </a>

        <a href="#" class="item1">
            <img src="../images/france1.png" alt="France" />
