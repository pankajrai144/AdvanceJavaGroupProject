                </div>
                <div class="info1">
                    <p class="text4">Portugal</p>
                    <p class="text5">Home Kit 2026</p>
                    <p class="text6">Classic deep red with clima-dry weave, mesh panels, and a tailored fit built for match intensity.</p>
                    <p class="text7">£74.99</p>
                    <a href="#" class="btn1">Add to Bag</a>
                </div>
            </div>

            <div class="card1">
                <div class="img1">
                    <img src="../images/bruno.jpg" alt="Portugal Away 2026" />
                    <span class="badge2">Away</span>
                </div>
                <div class="info1">
                    <p class="text4">Portugal</p>
                    <p class="text5">Away Kit 2026</p>
                    <p class="text6">Clean white with green trim. Lightweight recycled yarn with moisture-wicking for hot-weather fixtures.</p>
                    <p class="text7">£74.99</p>
                    <a href="#" class="btn1">Add to Bag</a>
                </div>
            </div>

            <div class="card1">
                <div class="img1">
                    <img src="../images/bruno1.jpg" alt="Portugal Third 2026" />
                    <span class="badge3">Third</span>
