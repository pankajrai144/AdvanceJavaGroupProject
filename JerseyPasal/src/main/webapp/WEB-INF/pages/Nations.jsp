        <a href="#portugal" class="np1 na2">&#8592; Prev</a>
        <div class="npg1">
            <a href="#portugal" class="np2 na3">1</a>
            <a href="#argentina" class="np2">2</a>
            <a href="#brazil" class="np2">3</a>
